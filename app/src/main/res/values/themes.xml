<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Chuyển sang MaterialComponents để khớp với Layout -->
    <style name="Base.Theme.CookingApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Các màu chính đã định nghĩa trong colors.xml -->
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="colorPrimaryVariant">@color/primary_orange</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Màu nền ứng dụng -->
        <item name="android:windowBackground">@color/bg_light</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_orange</item>
    </style>

    <style name="Theme.CookingApp" parent="Base.Theme.CookingApp" />
</resources>